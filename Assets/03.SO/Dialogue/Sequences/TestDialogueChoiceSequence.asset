  lines:
  - speakerName: Guide
    text: "\uC774 \uB300\uD654\uB294 DialogueSequenceSO \uC5D0\uC14B\uC5D0\uC11C
      \uC77D\uC5B4\uC635\uB2C8\uB2E4."
    choices: []
  - speakerName: Player
    text: "\uB300\uC0AC \uB0B4\uC6A9\uC740 \uC52C\uC774 \uC544\uB2C8\uB77C SO\uC5D0\uC11C
      \uAD00\uB9AC\uB418\uB2C8 \uC7AC\uC0AC\uC6A9\uD558\uAE30 \uC88B\uC2B5\uB2C8\uB2E4."
    choices: []
  - speakerName: Guide
    text: "\uC624\uB978\uCABD\uC5D0\uC11C \uD280\uC5B4\uB098\uC624\uB294 \uC120\uD0DD\uC9C0\uB97C
      \uACE8\uB77C \uBD84\uAE30\uB97C \uD14C\uC2A4\uD2B8\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    choices:
    - text: "\uC88B\uC544, \uACC4\uC18D \uC9C4\uD589"
      nextSequence: {fileID: 0}
      nextLineIndex: 3
      routes: []
    - text: "\uC5EC\uAE30\uC11C \uB05D\uB0B4\uAE30"
      nextSequence: {fileID: 0}
      nextLineIndex: -1
      routes: []
  - speakerName: Guide
    text: "\uC120\uD0DD\uC9C0\uB97C \uACE0\uB974\uBA74 DialogueRunner\uAC00 \uC9C0\uC815\uB41C
      \uC904\uB85C \uC774\uB3D9\uD569\uB2C8\uB2E4."
