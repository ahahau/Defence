  m_Script: {fileID: 11500000, guid: 47b6fbf626d84142a85744b0f9e1e3dc, type: 3}
  m_Name: StartTutorialDialogue
  m_EditorClassIdentifier: Assembly-CSharp::_01.Code.Dialogue.DialogueSequenceSO
  displayTitle: "\uD29C\uD1A0\uB9AC\uC5BC"
  lines:
  - speakerName: "\uAD00\uB9AC\uC790"
    text: "\uC790\uBB3C\uC1E0 \uD0C0\uC77C\uC744 \uB20C\uB7EC \uB358\uC804\uC744
      \uD655\uC7A5\uD558\uC138\uC694. \uD544\uC694\uD55C \uACE8\uB4DC\uB294
      \uC790\uBB3C\uC1E0 \uC544\uB798\uC5D0 \uD45C\uC2DC\uB429\uB2C8\uB2E4."
    enterActions: []
    choices: []
  - speakerName: "\uAD00\uB9AC\uC790"
    text: "\uBE48 \uD0C0\uC77C\uC744 \uD074\uB9AD\uD558\uBA74 \uC124\uCE58 \uD328\uB110\uC774
      \uC5F4\uB9BD\uB2C8\uB2E4. \uAC74\uBB3C, \uC720\uB2DB, \uD2B8\uB7A9,
      \uC7A5\uC2DD \uCE74\uD14C\uACE0\uB9AC \uC911 \uD558\uB098\uB97C \uACE0\uB974\uC138\uC694."
    enterActions: []
    choices: []
  - speakerName: "\uAD00\uB9AC\uC790"
    text: "\uD3EC\uD0C8\uC744 \uC124\uCE58\uD558\uBA74 \uC6E8\uC774\uBE0C \uC2DC\uC791
      \uBC84\uD2BC\uC774 \uD65C\uC131\uD654\uB429\uB2C8\uB2E4. \uBC30\uCE58\uAC00
      \uB05D\uB09C \uB4A4 \uC6E8\uC774\uBE0C\uB97C \uC2DC\uC791\uD558\uC138\uC694."
    enterActions: []
    choices: []
  - speakerName: "\uAD00\uB9AC\uC790"
    text: "\uC6E8\uC774\uBE0C\uB97C \uD074\uB9AC\uC5B4\uD558\uBA74 \uBCF4\uC0C1\uCC3D\uC774
      \uC5F4\uB9BD\uB2C8\uB2E4. \uBCF4\uC0C1\uC744 \uBC1B\uACE0 \uB2EB\uC73C\uBA74 \uB2E4\uC2DC
      \uAC74\uC124 \uB2E8\uACC4\uB85C \uB3CC\uC544\uC635\uB2C8\uB2E4."
    enterActions: []
    choices: []
  - speakerName: "\uAD00\uB9AC\uC790"
    text: "\uC804\uD22C \uC911\uC5D0\uB294 \uC801 \uC815\uBCF4\uC5D0\uC11C \uCCB4\uB825\uACFC
      \uC0C1\uD0DC\uC774\uC0C1\uC744 \uD655\uC778\uD558\uACE0, \uD568\uC815\uACFC
      \uC720\uB2DB \uBC30\uCE58\uB97C \uC870\uC815\uD558\uC138\uC694."
    enterActions: []
    choices:
    - text: "\uC2DC\uC791\uD558\uAE30"
      actions: []
      nextSequence: {fileID: 0}
      nextLineIndex: -1
      routes: []
