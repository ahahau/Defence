  lines:
  - speakerName: "\uBCF4\uAE09\uAD00"
    text: "\uBCF4\uAE09\uCC3D\uACE0\uC758 \uC7AC\uACE0\uAC00 \uBE60\uB974\uAC8C \uC904\uACE0 \uC788\uC2B5\uB2C8\uB2E4. \uC8FC\uBBFC\uB4E4\uC740 \uB354 \uC5C4\uACA9\uD55C \uBC30\uAE09\uC744 \uAC10\uC218\uD560 \uC218 \uC788\uB294\uC9C0 \uBB3B\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
